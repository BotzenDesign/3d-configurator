<!-- sections/3d-printing-coming-soon.liquid -->
<section class="3d-printing-coming-soon">
  <div class="glass-container">
    <div class="content">
      <div class="badge">🚀 Launching Soon</div>
      <h1>THE FUTURE OF <br><span>3D PRINTING.</span></h1>
      <p>We're building an elite, physics-accurate configurator for your custom prints. Get ready for instant quotes and stunning visuals.</p>
      
      <div id="countdown" class="countdown-grid">
        <div class="card"><span id="days">00</span><label>Days</label></div>
        <div class="card"><span id="hours">00</span><label>Hrs</label></div>
        <div class="card"><span id="minutes">00</span><label>Min</label></div>
        <div class="card"><span id="seconds">00</span><label>Sec</label></div>
      </div>

    </div>
  </div>
</section>

<style>
  .3d-printing-coming-soon {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #050505;
    color: #ffffff;
    padding: 40px 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    border-radius: 24px;
    margin: 40px 0;
    overflow: hidden;
    position: relative;
  }

  .3d-printing-coming-soon::before {
    content: '';
    position: absolute;
    top: -10%; left: -10%;
    width: 40%; height: 40%;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.2) 0%, transparent 70%);
    filter: blur(80px);
  }

  .glass-container {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 60px 40px;
    max-width: 800px;
    width: 100%;
    text-align: center;
    z-index: 10;
  }

  .badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(0, 188, 212, 0.1);
    border: 1px solid rgba(0, 188, 212, 0.3);
    border-radius: 100px;
    color: #00bcd4;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  h1 {
    font-size: clamp(40px, 8vw, 72px);
    line-height: 0.95;
    font-weight: 900;
    margin: 0 0 24px;
    letter-spacing: -2px;
  }

  h1 span {
    color: rgba(255, 255, 255, 0.4);
  }

  p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 18px;
    max-width: 500px;
    margin: 0 auto 48px;
    line-height: 1.6;
  }

  .countdown-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 48px;
  }

  .card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 24px 10px;
    display: flex;
    flex-direction: column;
  }

  .card span {
    font-size: 32px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  .card label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 4px;
  }

  .notify-form {
    display: flex;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 6px;
    border-radius: 100px;
    max-width: 400px;
    margin: 0 auto;
  }

  .notify-form input {
    background: transparent;
    border: none;
    color: white;
    padding: 12px 24px;
    flex-grow: 1;
    outline: none;
  }

  .notify-form button {
    background: #00bcd4;
    color: black;
    border: none;
    padding: 12px 24px;
    border-radius: 100px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .notify-form button:hover {
    transform: scale(1.05);
  }

  @media (max-width: 600px) {
    .countdown-grid { gap: 8px; }
    .card span { font-size: 24px; }
    .notify-form { border-radius: 20px; flex-direction: column; }
  }
</style>

<script>
  (function() {
    const launchDate = new Date();
    launchDate.setDate(launchDate.getDate() + 14); // 

    function update() {
      const now = new Date().getTime();
      const diff = launchDate - now;
      
      document.getElementById('days').innerText = Math.floor(diff / (1000 * 60 * 60 * 24)).toString().padStart(2, '0');
      document.getElementById('hours').innerText = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)).toString().padStart(2, '0');
      document.getElementById('minutes').innerText = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60)).toString().padStart(2, '0');
      document.getElementById('seconds').innerText = Math.floor((diff % (1000 * 60)) / 1000).toString().padStart(2, '0');
    }
    setInterval(update, 1000);
    update();
  })();
</script>

{% schema %}
{
  "name": "3D Printing Coming Soon",
  "settings": [],
  "presets": [
    {
      "name": "3D Printing Coming Soon"
    }
  ]
}
{% endschema %}
